#include <stdio.h>

int main() {
    int i;          // loop variable
    int sum = 0;    // variable to store sum

    // Loop from 1 to 10
    for(i = 1; i <= 10; i++) {
        printf("%d\n", i);
        sum = sum + i;   // adding numbers
    }

    printf("Sum of numbers from 1 to 10 = %d\n", sum);

    return 0;
}
