#include <stdio.h>

int main() {
    int i = 1;      // loop variable
    int sum = 0;    // variable to store sum

    // While loop from 1 to 10
    while(i <= 10) {
        printf("%d\n", i);
        sum = sum + i;   // adding numbers
        i++;             // increment
    }

    printf("Sum of numbers from 1 to 10 = %d\n", sum);

    return 0;
}
